generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MusicSource {
  spotify
  apple_music
  manual
}

enum SubscriptionStatus {
  free
  premium
}

model User {
  id                 String              @id @default(uuid())
  email              String?             @unique
  phone              String?             @unique
  isVerified         Boolean             @default(false)
  selfieUrl          String?
  displayName        String?
  age                Int?
  gender             String?
  genderPreference   String[]            @default([])
  relationshipIntent String?
  photos             String[]
  minAgePreference   Int?
  maxAgePreference   Int?
  maxDistanceKm      Int?
  locationOptIn      Boolean             @default(false)
  lastLatitude       Float?
  lastLongitude      Float?
  lastLocationAt     DateTime?
  lastActiveAt       DateTime?
  subscriptionStatus SubscriptionStatus  @default(free)
  pushToken          String?
  termsAcceptedAt    DateTime?
  isSuspended        Boolean             @default(false)
  suspendedAt        DateTime?
  suspendedReason    String?
  createdAt          DateTime            @default(now())

  musicProfile       MusicProfile?
  matchesAsA         Match[]             @relation("MatchUserA")
  matchesAsB         Match[]             @relation("MatchUserB")
  messages           Message[]
  reportsMade        Report[]            @relation("ReportsMade")
  reportsReceived    Report[]            @relation("ReportsReceived")
  likesSent          Like[]              @relation("LikesSent")
  likesReceived      Like[]              @relation("LikesReceived")
  matchReads         MatchRead[]
  locationPings      LocationPing[]
  blocksMade         Block[]             @relation("BlocksMade")
  blocksReceived      Block[]             @relation("BlocksReceived")
  icebreakerAnswers  IcebreakerAnswer[]  @relation("IcebreakerAnswers")
  crossingAlertsAsA  CrossingAlert[]     @relation("CrossingAlertUserA")
  crossingAlertsAsB  CrossingAlert[]     @relation("CrossingAlertUserB")
}

model CrossingAlert {
  id        String   @id @default(uuid())
  userAId   String
  userA     User     @relation("CrossingAlertUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userBId   String
  userB     User     @relation("CrossingAlertUserB", fields: [userBId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userAId, userBId])
}

model Block {
  id        String   @id @default(uuid())
  blockerId String
  blocker   User     @relation("BlocksMade", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId String
  blocked   User     @relation("BlocksReceived", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
}

model LocationPing {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  latitude  Float
  longitude Float
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model Like {
  id         String   @id @default(uuid())
  likerId    String
  liker      User     @relation("LikesSent", fields: [likerId], references: [id], onDelete: Cascade)
  likedId    String
  liked      User     @relation("LikesReceived", fields: [likedId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([likerId, likedId])
}

model MusicProfile {
  id           String      @id @default(uuid())
  userId       String      @unique
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  source       MusicSource
  topArtists   String[]
  topGenres    String[]
  topTracks    String[]
  energy       Float?
  valence      Float?
  tempoAvg     Float?
  updatedAt    DateTime    @updatedAt
}

model Match {
  id                     String    @id @default(uuid())
  userAId                String
  userBId                String
  userA                  User      @relation("MatchUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB                  User      @relation("MatchUserB", fields: [userBId], references: [id], onDelete: Cascade)
  compatibilityScore     Float
  compatibilityBreakdown Json
  photosRevealedByA      Boolean   @default(false)
  photosRevealedByB      Boolean   @default(false)
  createdAt              DateTime  @default(now())

  playlist               Playlist?
  messages               Message[]
  reads                  MatchRead[]
  icebreakerQuestions    IcebreakerQuestion[]

  @@unique([userAId, userBId])
}

model Playlist {
  id        String   @id @default(uuid())
  matchId   String   @unique
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  trackUris String[]
  createdAt DateTime @default(now())
}

model IcebreakerQuestion {
  id        String   @id @default(uuid())
  matchId   String
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  prompt    String
  order     Int
  createdAt DateTime @default(now())

  answers   IcebreakerAnswer[]

  @@index([matchId])
}

model IcebreakerAnswer {
  id         String             @id @default(uuid())
  questionId String
  question   IcebreakerQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  userId     String
  user       User               @relation("IcebreakerAnswers", fields: [userId], references: [id], onDelete: Cascade)
  answer     String
  createdAt  DateTime           @default(now())

  @@unique([questionId, userId])
}

model Message {
  id        String   @id @default(uuid())
  matchId   String
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())
}

model MatchRead {
  id         String   @id @default(uuid())
  matchId    String
  match      Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt DateTime @default(now())

  @@unique([matchId, userId])
}

enum ReportStatus {
  pending
  dismissed
  action_taken
}

model Report {
  id           String       @id @default(uuid())
  reporterId   String
  reporter     User         @relation("ReportsMade", fields: [reporterId], references: [id], onDelete: Cascade)
  reportedId   String
  reported     User         @relation("ReportsReceived", fields: [reportedId], references: [id], onDelete: Cascade)
  reason       String
  status       ReportStatus @default(pending)
  reviewedAt   DateTime?
  createdAt    DateTime     @default(now())
}

model WaitlistSignup {
  id                String   @id @default(uuid())
  email             String?  @unique
  phone             String?  @unique
  verified          Boolean  @default(false)
  verificationToken String?  @unique
  createdAt         DateTime @default(now())
}

model LoginCode {
  id        String    @id @default(uuid())
  email     String?
  phone     String?
  code      String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email, code])
  @@index([phone, code])
}
